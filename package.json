{
  "name": "react-use-superstate",
  "version": "1.0.4",
  "description": "Zero-boilerplate, key-based global state management for React. Built on useSyncExternalStore.",
  "author": "Sheikh Ahsan Talal",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "jsdom": "^25.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "keywords": [
    "react",
    "state",
    "global-state",
    "hooks",
    "useSyncExternalStore",
    "state-management",
    "typescript",
    "zero-boilerplate",
    "store",
    "react-hooks",
    "proxy-state",
    "signal-like",
    "fine-grained-reactivity"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Ahsan-Talal/react-use-superstate.git"
  },
  "bugs": {
    "url": "https://github.com/Ahsan-Talal/react-use-superstate/issues"
  },
  "homepage": "https://superstate-docs.vercel.app"
}
